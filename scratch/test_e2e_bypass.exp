#!/usr/bin/expect -f
set timeout 30
set host "14.207.128.141"
set user "admin1"
set pass "DigitalSm@rt"

spawn ssh -o StrictHostKeyChecking=no $user@$host
expect {
    "*assword:*" { send "$pass\r"; exp_continue }
    -re "admin1@pmisweb:.*\\$" {}
}

puts "\n--- 1. Generating SSO token on the SSO Backend ---"
send "SSO_RESPONSE=\$(curl -s -X POST https://dsp.ieat.go.th/api/sso/token -H 'Content-Type: application/json' -d '{\"userId\": \"pmis_dsp_user_001\", \"applicationId\": \"PMIS\"}')\r"
expect -re "admin1@pmisweb:.*\\$"
send "echo \"\$SSO_RESPONSE\"\r"
expect -re "admin1@pmisweb:.*\\$"

send "TOKEN=\$(echo \"\$SSO_RESPONSE\" | grep -o '\"token\":\"\[^\"]*\"' | cut -d'\"' -f4)\r"
expect -re "admin1@pmisweb:.*\\$"
send "echo \"SSO Token: \$TOKEN\"\r"
expect -re "admin1@pmisweb:.*\\$"

puts "\n--- 2. Call Nginx-proxied PMIS SSO Validate endpoint with the Token ---"
send "curl -i -s \"https://pmis-uat-phase2.wisdomcloud.net/api/v1/auth/sso-validate?token=\$TOKEN\"\r"
expect -re "admin1@pmisweb:.*\\$"

send "exit\r"
expect eof
