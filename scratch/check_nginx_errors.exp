#!/usr/bin/expect -f
set timeout 15
set host "14.207.128.138"
set user "admin1"
set pass "DigitalSm@rt"

spawn ssh -o StrictHostKeyChecking=no $user@$host
expect "*assword:*"
send "$pass\r"
expect "*\\$"

puts "\n--- Nginx Error Logs (Last 100 lines) ---"
send "sudo tail -n 100 /var/log/nginx/error.log\r"
expect {
    "*assword*" { send "$pass\r"; exp_continue }
    -re "admin1@digitalsmartfrontend:.*\\$" {}
}

send "exit\r"
expect eof
