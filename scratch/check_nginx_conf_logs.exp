#!/usr/bin/expect -f
set timeout 15
set host "14.207.128.138"
set user "admin1"
set pass "DigitalSm@rt"

spawn ssh -o StrictHostKeyChecking=no $user@$host
expect "*assword:*"
send "$pass\r"
expect "*\\$"

puts "\n--- Nginx Log configurations ---"
send "cat /etc/nginx/nginx.conf | grep -i log\r"
expect -re "admin1@digitalsmartfrontend:.*\\$"

send "exit\r"
expect eof
