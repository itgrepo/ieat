#!/usr/bin/expect -f
set timeout 15
set host "14.207.128.141"
set user "admin1"
set pass "DigitalSm@rt"

spawn ssh -o StrictHostKeyChecking=no $user@$host
expect {
    "*assword:*" { send "$pass\r"; exp_continue }
    -re "admin1@pmisweb:.*\\$" {}
}

puts "\n--- Reading /etc/nginx/conf.d/pmis_uat_ph2.conf ---"
send "cat /etc/nginx/conf.d/pmis_uat_ph2.conf\r"
expect -re "admin1@pmisweb:.*\\$"

send "exit\r"
expect eof
