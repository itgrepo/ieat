#!/usr/bin/expect -f
set timeout 30
set host "14.207.128.138"
set user "admin1"
set pass "DigitalSm@rt"

spawn ssh -o StrictHostKeyChecking=no $user@$host
expect {
    "*assword:*" { send -- "$pass\r"; exp_continue }
    "*\$*" { }
}

send "sudo ss -tulpn | grep -E ':80\\b'\r"
expect {
    "*password*" { send -- "$pass\r"; exp_continue }
    "*\$*" {}
}

send "exit\r"
expect eof
