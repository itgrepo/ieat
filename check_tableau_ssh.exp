#!/usr/bin/expect -f
set timeout 15
set host "14.207.128.138"
set user "admin1"
set pass "DigitalSm@rt"

spawn ssh -o ProxyJump=$user@$host -o StrictHostKeyChecking=no $user@192.168.9.157
expect {
    "*yes/no*" { send "yes\r"; exp_continue }
    "*assword:*" { send "$pass\r"; exp_continue }
    "*\\\$" {}
    timeout { exit 1 }
}

send "echo SUCCESS\r"
expect "*\\\$"
send "exit\r"
expect eof
