#!/usr/bin/expect -f
set timeout 10
set host "14.207.128.138"
set user "admin1"
set pass "DigitalSm@rt"

spawn ssh -o StrictHostKeyChecking=no $user@$host
expect "*assword:*"
send -- "$pass\r"
expect "*\$*"

send "echo '=== PING BACKEND ==='\r"
expect "*\$*"
send "ping -c 1 192.168.10.207 2>&1\r"
expect "*\$*"

send "echo '=== PORT 5000 CHECK ==='\r"
expect "*\$*"
send "nc -zv 192.168.10.207 5000 2>&1\r"
expect "*\$*"

send "echo '=== CURL HEALTH CHECK ==='\r"
expect "*\$*"
send "curl -I http://192.168.10.207:5000/health 2>&1\r"
expect "*\$*"

send "exit\r"
expect eof
