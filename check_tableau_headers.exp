#!/usr/bin/expect -f
set timeout 15
set host "14.207.128.138"
set user "admin1"
set pass "DigitalSm@rt"

spawn ssh -o StrictHostKeyChecking=no $user@$host
expect "*assword:*"
send "$pass\r"
expect "*\\$"

send "curl -sI http://192.168.9.157/ 2>&1 | head -30\r"
expect "*\\$"

send "curl -sI http://localhost/tableau/ 2>&1 | head -30\r"
expect "*\\$"

send "exit\r"
expect eof
